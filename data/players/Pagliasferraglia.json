    {
      "name": "Constructed Resilience",
      "source": "",
      "type": "passive",
      "description": "You have Resistance to Poison damage. You also have Advantage on saving throws to avoid or end the Poisoned condition.\n",
      "category": "",
      "actionType": null,
      "isMovement": false,
      "movementCost": 0,
      "resourceCost": null,
      "requirements": ""
    },
    {
      "name": "Sentry's Rest",
      "source": "",
      "type": "passive",
      "description": "You don’t need to sleep, and magic can’t put you to sleep. You can finish a Long Rest in 6 hours if you spend those hours in an inactive, motionless state. During this time, you appear inert but remain conscious.",
      "category": "",
      "actionType": null,
      "isMovement": false,
      "movementCost": 0,
      "resourceCost": null,
      "requirements": ""
    },
    {
      "name": "Integrated Protection",
      "source": "",
      "type": "passive",
      "description": "You gain a +1 bonus to your Armor Class. In addition, armor you have donned can’t be removed against your will while you’re alive.\n",
